{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://thekey.local/schemas/sovereign-authorization-receipt-v1.json","title":"SovereignAuthorizationReceipt v1","type":"object","additionalProperties":false,"required":["schema_version","protocol_version","authorization_id","grant_id","grant_sha256","sovereign_identity_id","run_id","transaction_id","plan_sha256","allowed_action_ids","issued_at","authority_basis","authorization_scope","subject_relative_path","subject_sha256","output_scope","production_reuse"],"properties":{"schema_version":{"const":"v1"},"protocol_version":{"const":"v1"},"authorization_id":{"type":"string","minLength":3,"maxLength":128},"grant_id":{"type":"string","minLength":3,"maxLength":128},"grant_sha256":{"type":"string","pattern":"^(?!0{64}$)[0-9a-f]{64}$"},"sovereign_identity_id":{"type":"string","minLength":1,"maxLength":128},"run_id":{"type":"string","minLength":3,"maxLength":128},"transaction_id":{"type":"string","minLength":3,"maxLength":128},"plan_sha256":{"type":"string","pattern":"^(?!0{64}$)[0-9a-f]{64}$"},"allowed_action_ids":{"type":"array","minItems":1,"maxItems":32,"uniqueItems":true,"items":{"type":"string","minLength":1}},"issued_at":{"type":"string","format":"date-time"},"authority_basis":{"type":"string","minLength":12,"maxLength":512},"authorization_scope":{"const":"JUDGE_MODE_DEMO_ONLY"},"subject_relative_path":{"const":"examples/demo_app/calculator.py"},"subject_sha256":{"type":"string","pattern":"^(?!0{64}$)[0-9a-f]{64}$"},"output_scope":{"const":"ISOLATED_RUN_WORKSPACE_ONLY"},"production_reuse":{"const":false}}}
