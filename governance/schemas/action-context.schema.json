{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://thekey.local/schemas/action-context-v1.json","title":"ActionContext v1","type":"object","additionalProperties":false,"required":["schema_version","protocol_version","actor_id","role","transaction_id","authorization_id","run_id","plan_sha256","policy_version","policy_bundle_hash","requested_at","review_verdict","checkmate_receipt","sovereign_receipt"],"properties":{"schema_version":{"const":"v1"},"protocol_version":{"const":"v1"},"actor_id":{"type":"string","minLength":1,"maxLength":128},"role":{"enum":["AUTHOR","EXECUTOR","REVIEWER","APPROVER","SOVEREIGN","SYSTEM"]},"transaction_id":{"type":"string","minLength":3,"maxLength":128},"authorization_id":{"type":"string","minLength":3,"maxLength":128},"run_id":{"type":"string","minLength":3,"maxLength":128},"plan_sha256":{"type":"string","pattern":"^(?!0{64}$)[0-9a-f]{64}$"},"policy_version":{"type":"string","minLength":1,"maxLength":64},"policy_bundle_hash":{"type":"string","pattern":"^(?!0{64}$)[0-9a-f]{64}$"},"requested_at":{"type":"string","format":"date-time"},"review_verdict":{"enum":["PASS","DEFER","FAIL","PENDING"]},"checkmate_receipt":{"type":"object"},"sovereign_receipt":{"type":"object"}}}
