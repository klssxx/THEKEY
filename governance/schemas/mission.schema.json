{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "THEKEY Mission v1.0",
  "description": "The immutable intent handed to the governed run. Frozen at submission; every actor derives context from it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mission_id", "title", "description", "actor_profile", "target", "policy_id"],
  "properties": {
    "mission_id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "actor_profile": {
      "type": "string",
      "enum": ["MiMo", "THEKEY", "HY3", "generic"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["python_project", "npsc_adapter", "demo"] },
        "path": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "policy_id": { "type": "string", "minLength": 1 },
    "auto_approve": { "type": "boolean", "default": true },
    "created_at": { "type": "string" },
    "source_inputs": { "type": "array", "items": { "type": "object" } }
  }
}
