{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "THEKEY Phase Contract v1.0",
  "type": "object",
  "required": [
    "phase_contract",
    "authoritative_state",
    "role_permissions",
    "flags",
    "required_inputs",
    "allowed_roots",
    "protected_paths",
    "allowed_operations",
    "allowed_command_ids",
    "allowed_outputs",
    "allowed_transitions",
    "budgets",
    "rollback",
    "required_evidence",
    "task",
    "success_conditions",
    "stop_conditions",
    "output_schema"
  ],
  "properties": {
    "phase_contract": {
      "type": "object",
      "required": ["contract_version", "run_id", "phase_id", "phase_type", "role"],
      "properties": {
        "contract_version": { "type": "string" },
        "run_id": { "type": "string" },
        "phase_id": { "type": "string" },
        "phase_type": { "enum": ["CONTROL", "WORK", "RECOVERY"] },
        "role": { "enum": ["PLANNER", "EXECUTOR", "VERIFIER", "APPROVER"] }
      }
    },
    "authoritative_state": {
      "type": "object",
      "required": ["current", "version", "sha256"],
      "properties": {
        "current": { "type": "string" },
        "version": { "type": "integer" },
        "sha256": { "type": "string" }
      }
    },
    "role_permissions": { "type": "object" },
    "flags": { "type": "object" },
    "required_inputs": { "type": "array" },
    "allowed_roots": { "type": "array", "items": { "type": "string" } },
    "protected_paths": { "type": "array", "items": { "type": "string" } },
    "allowed_operations": { "type": "array", "items": { "type": "string" } },
    "allowed_command_ids": { "type": "array", "items": { "type": "string" } },
    "allowed_outputs": { "type": "array" },
    "allowed_transitions": { "type": "array", "items": { "type": "string" } },
    "budgets": { "type": "object" },
    "rollback": { "type": "object" },
    "required_evidence": { "type": "array" },
    "task": { "type": "string" },
    "success_conditions": { "type": "array" },
    "stop_conditions": { "type": "array" },
    "output_schema": { "type": "string" }
  }
}
